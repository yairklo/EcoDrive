generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  preferences  Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  vehicles     Vehicle[]
}

model Vehicle {
  id           String      @id @default(uuid())
  ownerId      String
  owner        User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  type         VehicleType
  fuelCapacity Float       // In liters
  kCity        Float       @default(1.0)
  kHighway     Float       @default(1.0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  refuelLogs   RefuelLog[]
  tripSyncs    TripSync[]
}

model TripSync {
  id                    String   @id @default(uuid())
  clientUuid            String?  @unique
  vehicleId             String
  vehicle               Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  timestamp             DateTime @default(now())
  distanceCityKm        Float
  distanceHighwayKm     Float
  accelerationPenaltyMl Float
  createdAt             DateTime @default(now())
}

model RefuelLog {
  id                   String   @id @default(uuid())
  clientUuid           String?  @unique
  vehicleId            String
  vehicle              Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  timestamp            DateTime @default(now())
  odometer             Int
  litersPumped         Float
  costPerLiter         Float
  predictedCityBurn    Float    @default(0)
  predictedHighwayBurn Float    @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

enum VehicleType {
  Sedan
  SUV
  Compact
  Hybrid
}
